# Blog / docs front-end (Next.js SEO: canonicals, sitemap, OG, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://blog.propertycareapp.com
NEXT_PUBLIC_SITE_NAME=Property Care App
# Link preview / default SEO (home + site fallback). If unset, title uses "{SITE_NAME} — Knowledge Base & Blog".
NEXT_PUBLIC_SITE_DEFAULT_TITLE=
NEXT_PUBLIC_SITE_DEFAULT_DESCRIPTION=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Local override tip: in `.env.local` set NEXT_PUBLIC_SITE_URL=http://localhost:3000 while developing.

# Upstream content API base URL (no trailing slash)
API_BASE_URL=https://api.propertycareapp.com
#API_BASE_URL=http://localhost:6001

# Backward compatibility fallback used by older code paths
BASE_URL=https://api.propertycareapp.com
#BASE_URL=http://localhost:6001

# Content category IDs (Help Center root in subscription admin — children show on home)
BLOG_CATEGORY_ID=1424
#BLOG_CATEGORY_ID=1011

# Language for blog API (`EN`, `FI`, …)
BLOG_DEFAULT_LANGUAGE=EN

# Optional: base URL for category icons (filename from API appended)
#NEXT_PUBLIC_API_URL_PHOTO=https://cdn.example.com/blog-icons/

# Subscription service
SUBSCRIPTION_API_KEY=83ad5b9c-52ab-487e-9e7e-fb0993f30362
#SUBSCRIPTION_API_KEY=ab513eda-e603-47c6-a54d-9f4878089c4d
